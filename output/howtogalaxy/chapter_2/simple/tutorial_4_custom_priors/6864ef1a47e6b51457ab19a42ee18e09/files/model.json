{
    "type": "collection",
    "arguments": {
        "galaxies": {
            "type": "collection",
            "arguments": {
                "galaxy": {
                    "class_path": "autogalaxy.galaxy.galaxy.Galaxy",
                    "type": "model",
                    "arguments": {
                        "redshift": {
                            "type": "Constant",
                            "value": 0.5
                        },
                        "bulge": {
                            "class_path": "autogalaxy.profiles.light.standard.sersic.Sersic",
                            "type": "model",
                            "arguments": {
                                "centre": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "centre_0": {
                                            "type": "Uniform",
                                            "id": 30,
                                            "lower_limit": -0.05,
                                            "upper_limit": 0.05
                                        },
                                        "centre_1": {
                                            "type": "Uniform",
                                            "id": 31,
                                            "lower_limit": -0.05,
                                            "upper_limit": 0.05
                                        }
                                    }
                                },
                                "ell_comps": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "ell_comps_0": {
                                            "type": "TruncatedGaussian",
                                            "id": 34,
                                            "mean": 0.333333,
                                            "sigma": 0.1,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        },
                                        "ell_comps_1": {
                                            "type": "TruncatedGaussian",
                                            "id": 35,
                                            "mean": 0.0,
                                            "sigma": 0.1,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        }
                                    }
                                },
                                "intensity": {
                                    "type": "LogUniform",
                                    "id": 21,
                                    "lower_limit": 1e-06,
                                    "upper_limit": 1000000.0
                                },
                                "effective_radius": {
                                    "type": "TruncatedGaussian",
                                    "id": 38,
                                    "mean": 1.0,
                                    "sigma": 0.8,
                                    "lower_limit": 0.0,
                                    "upper_limit": Infinity
                                },
                                "sersic_index": {
                                    "type": "TruncatedGaussian",
                                    "id": 40,
                                    "mean": 3.0,
                                    "sigma": 1.0,
                                    "lower_limit": 0.0,
                                    "upper_limit": Infinity
                                }
                            }
                        },
                        "disk": {
                            "class_path": "autogalaxy.profiles.light.standard.exponential.Exponential",
                            "type": "model",
                            "arguments": {
                                "centre": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "centre_0": {
                                            "type": "Uniform",
                                            "id": 32,
                                            "lower_limit": -0.05,
                                            "upper_limit": 0.05
                                        },
                                        "centre_1": {
                                            "type": "Uniform",
                                            "id": 33,
                                            "lower_limit": -0.05,
                                            "upper_limit": 0.05
                                        }
                                    }
                                },
                                "ell_comps": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "ell_comps_0": {
                                            "type": "TruncatedGaussian",
                                            "id": 36,
                                            "mean": 0.333333,
                                            "sigma": 0.1,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        },
                                        "ell_comps_1": {
                                            "type": "TruncatedGaussian",
                                            "id": 37,
                                            "mean": 0.0,
                                            "sigma": 0.1,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        }
                                    }
                                },
                                "intensity": {
                                    "type": "LogUniform",
                                    "id": 28,
                                    "lower_limit": 1e-06,
                                    "upper_limit": 1000000.0
                                },
                                "effective_radius": {
                                    "type": "TruncatedGaussian",
                                    "id": 39,
                                    "mean": 1.0,
                                    "sigma": 0.8,
                                    "lower_limit": 0.0,
                                    "upper_limit": Infinity
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}