                            "arguments": {
                                "centre": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "centre_0": {
                                            "type": "Gaussian",
                                            "id": 11,
                                            "mean": 0.0,
                                            "sigma": 0.3
                                        },
                                        "centre_1": {
                                            "type": "Gaussian",
                                            "id": 12,
                                            "mean": 0.0,
                                            "sigma": 0.3
                                        }
                                    }
                                },
                                "ell_comps": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "ell_comps_0": {
                                            "type": "TruncatedGaussian",
                                            "id": 2,
                                            "mean": 0.0,
                                            "sigma": 0.3,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        },
                                        "ell_comps_1": {
                                            "type": "TruncatedGaussian",
                                            "id": 3,
                                            "mean": 0.0,
                                            "sigma": 0.3,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        }
                                    }
                                },
                                "effective_radius": {
                                    "type": "Uniform",
                                    "id": 4,
                                    "lower_limit": 0.0,
                                    "upper_limit": 30.0
                                },
                                "sersic_index": {
                                    "type": "TruncatedGaussian",
                                    "id": 17,
                                    "mean": 4.0,
                                    "sigma": 2.0,
                                    "lower_limit": 0.0,
                                    "upper_limit": 5.0
                                }
                            }
                        },
                        "disk": {
                            "class_path": "autogalaxy.profiles.light.linear.sersic.Sersic",
                            "type": "model",
                            "arguments": {
                                "centre": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "centre_0": {
                                            "type": "Gaussian",
                                            "id": 18,
                                            "mean": 0.0,
                                            "sigma": 0.3
                                        },
                                        "centre_1": {
                                            "type": "Gaussian",
                                            "id": 19,
                                            "mean": 0.0,
                                            "sigma": 0.3
                                        }
                                    }
                                },
                                "ell_comps": {
                                    "type": "tuple_prior",
                                    "arguments": {
                                        "ell_comps_0": {
                                            "type": "TruncatedGaussian",
                                            "id": 20,
                                            "mean": 0.0,
                                            "sigma": 0.3,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        },
                                        "ell_comps_1": {
                                            "type": "TruncatedGaussian",
                                            "id": 21,
                                            "mean": 0.0,
                                            "sigma": 0.3,
                                            "lower_limit": -1.0,
                                            "upper_limit": 1.0
                                        }
                                    }
                                },
                                "effective_radius": {
                                    "type": "Uniform",
                                    "id": 10,
                                    "lower_limit": 0.0,
                                    "upper_limit": 30.0
                                },
                                "sersic_index": {
                                    "type": "TruncatedGaussian",
                                    "id": 24,
                                    "mean": 1.0,
                                    "sigma": 2.0,
                                    "lower_limit": 0.0,
                                    "upper_limit": 5.0
